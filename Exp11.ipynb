        "import pandas as pd\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "# Load dataset\n",
        "df = pd.read_csv('customers-100.csv')\n",
        "\n",
        "# Basic analysis\n",
        "print(df.head())\n",
        "print(df['Country'].value_counts())\n",
        "\n",
        "# Plot graph\n",
        "df['Country'].value_counts().head(5).plot(kind='bar')\n",
        "\n",
        "plt.title(\"Top 5 Countries\")\n",
        "plt.show()"
